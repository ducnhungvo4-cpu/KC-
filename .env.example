PORT=8787
LOGIN_PASSWORD=kc8888
AUTH_SECRET=replace-with-a-long-random-string

# Seedream 5.0 Lite image generation
SEEDREAM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDREAM_API_KEY=
SEEDREAM_MODEL_ID=doubao-seedream-5-0-260128
SEEDREAM_IMAGE_ENDPOINT=/images/generations
SEEDREAM_SIZE=2K
SEEDREAM_WATERMARK=true

# Seedance 1.5 Pro video generation (legacy fallback, optional)
SEEDANCE_BASE_URL=https://api.example.com
SEEDANCE_API_KEY=
SEEDANCE_MODEL_ID=doubao-seedance-1-5-pro
SEEDANCE_VIDEO_ENDPOINT=/v1/videos

# Agnes Video V2.0 video generation (primary, async create + poll)
# Docs: https://agnes-ai.com/doc/agnes-video-v20
AGNES_VIDEO_BASE_URL=https://apihub.agnes-ai.com
AGNES_VIDEO_API_KEY=
AGNES_VIDEO_MODEL_ID=agnes-video-v2.0
AGNES_VIDEO_CREATE_ENDPOINT=/v1/videos
AGNES_VIDEO_QUERY_ENDPOINT=/v1/videos
AGNES_VIDEO_FPS=24
AGNES_VIDEO_POLL_INTERVAL_MS=6000
AGNES_VIDEO_TIMEOUT_MS=270000
# Optional tuning:
# AGNES_VIDEO_INFERENCE_STEPS=
# AGNES_VIDEO_NEGATIVE_PROMPT=
# AGNES_VIDEO_DEFAULT_PROMPT=

# Xiaomi MiMo text, image understanding, video understanding
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_API_KEY=
MIMO_TEXT_MODEL_ID=mimo-v2.5-pro
MIMO_VISION_MODEL_ID=mimo-v2.5
MIMO_TEXT_ENDPOINT=/chat/completions
MIMO_MAX_COMPLETION_TOKENS=4096
MIMO_MEDIA_MAX_COMPLETION_TOKENS=4096

# Qwen Image Edit multi-angle generation
DASHSCOPE_API_KEY=
QWEN_EDIT_BASE_URL=https://dashscope.aliyuncs.com/api/v1
QWEN_EDIT_ENDPOINT=/services/aigc/multimodal-generation/generation
QWEN_EDIT_MODEL=qwen-image-edit-plus-2025-12-15
QWEN_EDIT_WATERMARK=true
